# LLM API Configuration (OpenAI-compatible)
# For OpenAI: https://api.openai.com/v1
# For other providers: use their endpoint URL
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=You know what goes here hehe :)
LLM_MODEL_NAME=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

# Application Settings
DEBUG=false
APP_NAME=PDF RAG Pipeline
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# Vector Store
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=pdf_knowledge_base

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
DEFAULT_TOP_K=4
MAX_TOP_K=10

# Note: Place your PDF at ./dataset/dataset.pdf